{
  "name": "framesnap",
  "private": true,
  "description": "Application FrameSnap",
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Nitatemic",
    "email": "alexandre@nitatemic.dev"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:desktop": "cross-env VITE_ELECTRON=true vite",
    "build:desktop": "cross-env VITE_ELECTRON=true vite build && electron-builder -mwl",
    "build:desktop:ci": "cross-env VITE_ELECTRON=true vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "dev.nitatemic.framesnap",
    "productName": "FrameSnap",
    "icon": "build/icon.png",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "maintainer": "Nitatemic <alexandre@nitatemic.dev>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
